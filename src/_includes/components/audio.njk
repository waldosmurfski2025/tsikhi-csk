<div class="media {{ position | default('tright') }}">

    <div class="media-inner">

        <audio controls preload="metadata">

            <source src="{{ audio.src }}"
                    type="{{ audio.type }}">

            Your browser does not support audio.

        </audio>

        {% if audio.caption %}

        <div class="media-caption">

            {{ audio.caption }}

        </div>

        {% endif %}

    </div>

</div>