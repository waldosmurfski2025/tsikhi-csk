{% if navbox %}

<nav class="navbox {{ navbox.theme | default('history') }}">

    {% if navbox.title %}

    <div class="navbox-title">
        {{ navbox.title }}
    </div>

    {% endif %}

    {% for section in navbox.sections %}

    <div class="navbox-row">

        <div class="navbox-label">
            {{ section.label }}
        </div>

        <div class="navbox-links">

{% for link in section.links %}

<div class="navbox-link">

{% if link.icon %}
<img
    src="{{ link.icon | url }}"
    alt="{{ link.alt or '' }}"
    class="navbox-icon">
{% endif %}

    {% if link.url %}
        <a href="{{ link.url | url }}">
            {{ link.title }}
        </a>
    {% else %}
        {{ link.title }}
    {% endif %}

    {% if link.description %}
        <span class="navbox-description">
            — {{ link.description }}
        </span>
    {% endif %}

</div>

{% endfor %}

</div>

    </div>

    {% endfor %}

</nav>

{% endif %}