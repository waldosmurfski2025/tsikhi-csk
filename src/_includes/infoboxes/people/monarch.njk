<aside class="infobox">

    <h3>{{ person.title }}</h3>

    <h2>{{ person.name }}</h2>

    <img src="{{ person.image }}"
         alt="{{ person.name }}">

    <table>

        <tr>
            <th>Born</th>
            <td>{{ person.born }}</td>
        </tr>

        <tr>
            <th>Nationality</th>
            <td>{{ person.nationality }}</td>
        </tr>

        <tr>
            <th>Occupation</th>
            <td>{{ person.occupation }}</td>
        </tr>

        <tr>
            <th>Political Party</th>
            <td>{{ person.party }}</td>
        </tr>

    </table>

</aside>